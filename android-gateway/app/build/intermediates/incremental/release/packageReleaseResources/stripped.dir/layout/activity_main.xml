<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0e1a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HYDROPY"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#00e5ff"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textSize="11sp"
                android:textColor="#4a5568"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ── Permission warning card (hidden when granted) ── -->
        <LinearLayout
            android:id="@+id/cardPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠  PERMISSIONS REQUIRED"
                android:textSize="11sp"
                android:textColor="#f59e0b"
                android:letterSpacing="0.1"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvPermissionDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS and phone permissions are needed to send messages."
                android:textSize="13sp"
                android:textColor="#94a3b8"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnGrantPermissions"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="GRANT PERMISSIONS"
                android:textColor="#000000"
                android:backgroundTint="#f59e0b"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── Status card ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textSize="10sp"
                android:textColor="#4a5568"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not configured"
                android:textSize="16sp"
                android:textColor="#e2e8f0"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvDeviceId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#4a5568"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvSmsSent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#00e5ff"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Setup section (shown when NOT paired) ─────── -->
        <LinearLayout
            android:id="@+id/sectionSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Server URL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVER URL"
                    android:textSize="10sp"
                    android:textColor="#4a5568"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/etServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://your-replit-url.replit.dev"
                    android:textColor="#e2e8f0"
                    android:textColorHint="#4a5568"
                    android:background="@null"
                    android:inputType="textUri"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Pair Code -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAIR CODE"
                    android:textSize="10sp"
                    android:textColor="#4a5568"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/etPairCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="XXXXXX"
                    android:textColor="#00e5ff"
                    android:textColorHint="#4a5568"
                    android:background="@null"
                    android:inputType="textCapCharacters|textNoSuggestions"
                    android:fontFamily="monospace"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.3"
                    android:layout_marginTop="4dp"
                    android:maxLength="8" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get from Dashboard → Devices → Pair New Device"
                    android:textSize="11sp"
                    android:textColor="#4a5568"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CONNECT DEVICE"
                android:textColor="#000000"
                android:backgroundTint="#00e5ff"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── Connected section (shown when paired) ──────── -->
        <LinearLayout
            android:id="@+id/sectionConnected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENT TODAY"
                        android:textSize="9sp"
                        android:textColor="#4a5568"
                        android:letterSpacing="0.15"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvSentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#00e5ff"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PENDING"
                        android:textSize="9sp"
                        android:textColor="#4a5568"
                        android:letterSpacing="0.15"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvPendingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#e2e8f0"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Server info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTED TO"
                    android:textSize="9sp"
                    android:textColor="#4a5568"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#94a3b8"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:ellipsize="middle"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Recent log -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECENT ACTIVITY"
                    android:textSize="9sp"
                    android:textColor="#4a5568"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="#64748b"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="DISCONNECT &amp; RESET"
                android:textColor="#e2e8f0"
                android:backgroundTint="#1e2433"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textSize="13sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
