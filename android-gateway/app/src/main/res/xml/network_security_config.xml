<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow HTTPS to all domains (Replit uses standard certs).
    Cleartext (plain HTTP) is blocked — users must use https:// URLs.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
